# InferenceWall Environment Variables
# Copy to .env.local and fill in values

# API Keys (generate with: inferwall admin setup)
# IW_API_KEY=iwk_scan_...
# IW_ADMIN_KEY=iwk_admin_...

# Server
IW_HOST=0.0.0.0
IW_PORT=8000

# TLS: auto, off, acme
IW_TLS=off

# Profile: lite, standard, full
IW_PROFILE=lite

# Logging
IW_LOG_LEVEL=info

# Redis (for distributed sessions)
# IW_REDIS_URL=redis://localhost:6379

# Log encryption key
# IW_LOG_ENCRYPTION_KEY=iwlk_...

# ELK SIEM testing facility — ship scan/audit logs to Logstash
# IW_ELK_URL=http://localhost:8080
